# electron-builder 打包主进程依赖时，需要「类 npm」的平铺 node_modules；
# pnpm 默认 isolated linker 时，打进 app.asar 的依赖可能断链，运行报错如 Cannot find module '@nut-tree-fork/nut-js'。
#
# 二选一：
# 1) 本文件已设 node-linker=hoisted，请在本机执行：pnpm install
# 2) 或打包前执行：npm run deps:npm   （与 package-lock.json 一致，最稳）
node-linker=hoisted

# Electron / electron-builder 二进制国内镜像（避免下载卡住）
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
