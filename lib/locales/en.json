  "help.contact": "Contact",
  "help.quickstartDesc": "Follow these steps to get the most out of your meeting experience.",
  "help.step1title": "Set Your Name",
  "help.step1desc": "Enter your display name in the pre-join screen so other participants can identify you easily.",
  "help.step2title": "Configure Audio & Video",
  "help.step2desc": "Use the microphone and camera controls to check your devices before joining. Click the chevron (▲) for advanced device selection.",
  "help.step3title": "Join the Meeting",
  "help.step3desc": "Click 'Join Now' or 'Start Now' to enter the meeting room. Your audio and video will activate automatically.",
  "help.step4title": "Invite Others",
  "help.step4desc": "Use the 'Invite' button in the toolbar to copy the meeting link to your clipboard and share it with participants.",
  "help.step5title": "Stay Secure",
  "help.step5desc": "Only share the meeting link with trusted participants. The host can remove participants or end the meeting at any time.",
  "help.proTip": "Pro Tip",
  "help.proTipDesc": "The meeting link is automatically copied to your clipboard when you join. Paste it anywhere to invite others instantly.",
  "help.shortcutsDesc": "Use these keyboard shortcuts to control your meeting without touching your mouse.",
  "help.shortcutMic": "Toggle Microphone (Mute / Unmute)",
  "help.shortcutCam": "Toggle Camera (On / Off)",
  "help.shortcutShare": "Start / Stop Screen Share",
  "help.shortcutEsc": "Close panels and dialogs",
  "help.shortcutsNote": "Keyboard shortcuts are active when the meeting window is focused. If a shortcut doesn't work, click anywhere on the meeting area first.",
  "help.faqDesc": "Answers to the most frequently asked questions.",
  "help.faq1q": "My microphone or camera isn't working. What should I do?",
  "help.faq1a": "Make sure your browser has permission to access your microphone and camera. In Chrome, click the lock icon in the address bar → Site Settings → Allow Camera and Microphone. Then refresh the page.",
  "help.faq2q": "Can I share my screen during a meeting?",
  "help.faq2a": "Yes! Click the 'Share Screen' button in the toolbar. On mobile devices, screen sharing may require the Kloud Meet native app. Only one participant can share their screen at a time.",
  "help.faq3q": "How do I invite someone to the meeting?",
  "help.faq3a": "Click the 'Invite' button in the toolbar, or simply copy the URL from your browser's address bar. The meeting link is also automatically copied to your clipboard when you join.",
  "help.faq4q": "What is Live Doc?",
  "help.faq4a": "Live Doc is a real-time collaborative document shared among all meeting participants. Switch to it using the 'Live Doc' tab in the toolbar. All edits are synced instantly.",
  "help.faq5q": "How do I end the meeting for everyone?",
  "help.faq5a": "Only the host or co-host can end the meeting for all participants. Click the red 'Exit' button → 'End meeting for everyone'. Participants will see a meeting concluded screen.",
  "help.contactDesc": "Need more help? Reach out through any of the channels below.",
