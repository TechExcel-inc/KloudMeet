# 1. Copy this file and rename it to .env.local
# 2. Update the enviroment variables below.

# REQUIRED SETTINGS
# ################# 
# If you are using LiveKit Cloud, the API key and secret can be generated from the Cloud Dashboard.
LIVEKIT_API_KEY=APIjeJeEsmExKfF
LIVEKIT_API_SECRET=0iIKcQhjyzzTtGdCKJXhVhDxfcFI5lLIDUfrVSohXzO
# URL pointing to the LiveKit server. (example: `wss://my-livekit-project.livekit.cloud`)
LIVEKIT_URL=wss://kloud-2qfdwrsw.livekit.cloud


# OPTIONAL SETTINGS
# ################# 
# Recording
# S3_KEY_ID=
# S3_KEY_SECRET=
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=

# PUBLIC
# Uncomment settings menu when using a LiveKit Cloud, it'll enable Krisp noise filters.
# NEXT_PUBLIC_SHOW_SETTINGS_MENU=true
# NEXT_PUBLIC_LK_RECORD_ENDPOINT=/api/record

# LiveDoc (iframe MainStage + meeting instance API)
# NEXT_PUBLIC_LIVEDOC_BASE_URL=https://kloud.cn
# LIVEDOC_SERVER_API_BASE_URL=https://wss.peertime.cn/MeetingServer
# PEER_TIME_API_BASE_URL=https://api.peertime.cn

# Optional, to pipe logs to datadog
# NEXT_PUBLIC_DATADOG_CLIENT_TOKEN=client-token
# NEXT_PUBLIC_DATADOG_SITE=datadog-site

# ELECTRON / STANDALONE PACKAGING (npm run electron:pack / electron:dist)
# =============================================================================
# - Server secrets (LIVEKIT_API_* , LIVEKIT_URL): use .env.production and/or .env.local on the machine
#   that runs the build. prepare-standalone copies them into .next/standalone so the packaged app can read them.
# - NEXT_PUBLIC_* variables are compiled into the browser bundle at `next build` time only. They must already
#   be set in .env.production / .env.local when you build, or they will be missing in the installed .exe.

