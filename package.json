{
  "name": "livekit-meet",
  "version": "0.2.5",
  "private": true,
  "description": "Kloud Meet — LiveKit + Next.js desktop and web client",
  "author": "Kloud",
  "main": "main.js",
  "scripts": {
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://127.0.0.1:3201 && electron .\"",
    "dev": "next dev -p 3201 --turbopack",
    "build": "next build",
    "electron:ensure": "node scripts/ensure-electron.js",
    "electron:prepare-standalone": "node scripts/prepare-standalone.js",
    "electron:prepare-app": "node scripts/prepare-electron-app.js",
    "electron:pack": "npm run build && npm run electron:prepare-standalone && npm run electron:prepare-app",
    "deps:npm": "npm ci --legacy-peer-deps",
    "electron:dist": "npm run electron:ensure && npm run electron:pack && node scripts/run-electron-builder.js --project .electron-app --win",
    "electron:dist:reuse": "npm run electron:ensure && npm run electron:prepare-standalone && npm run electron:prepare-app && node scripts/run-electron-builder.js --project .electron-app --win",
    "electron:dist:skip-rcedit": "npm run electron:ensure && npm run electron:pack && node scripts/run-electron-builder.js --project .electron-app --win --config.win.signAndEditExecutable=false",
    "start": "next start -p 3201 -H 0.0.0.0",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "vitest run",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "build:electron": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/ && electron-builder --mac"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "@datadog/browser-logs": "^5.23.3",
    "@getbrevo/brevo": "^5.0.4",
    "@livekit/components-react": "2.9.20",
    "@livekit/components-styles": "1.2.0",
    "@livekit/krisp-noise-filter": "0.4.1",
    "@livekit/track-processors": "^0.7.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "livekit-client": "2.17.3",
    "livekit-server-sdk": "2.15.0",
    "next": "15.2.8",
    "prisma": "^5.22.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hot-toast": "^2.5.2",
    "tinykeys": "^3.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "24.10.13",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "9.39.1",
    "eslint-config-next": "15.5.6",
    "prettier": "3.7.3",
    "source-map-loader": "^5.0.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.18.2",
  "build": {
    "appId": "com.techexcel.kloudmeet",
    "productName": "Kloud Meet",
    "protocols": [
      {
        "name": "Kloud Meet",
        "schemes": [
          "kloudmeet"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "update-progress.html",
      "update-progress-preload.js",
      "update-ready.html",
      "update-ready-preload.js",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/@nut-tree-fork/**"
    ],
    "extraResources": [
      {
        "from": ".next",
        "to": ".",
        "filter": [
          "standalone",
          "standalone/**/*"
        ]
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://kloud.cn/kloudmeet-exe"
    },
    "win": {
      "executableName": "KloudMeet",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
